        else if (slot > 0)
        {
            // Show texture from game if we have it
            if (actionBarTextureReader.TryGetTexture(slot, out var textureId))
            {
                parts.Add($"Slot {slot}: In-game (tex:{textureId})");
            }
            else
            {
                parts.Add($"Slot {slot}: Empty");
            }
        }

        // Add slot-based reader info (cost, cooldown, usable status)
        string slotInfo = GetSlotInfo(action);
        if (!string.IsNullOrEmpty(slotInfo))
            parts.Add(slotInfo);

        return parts.Count > 0 ? string.Join(" | ", parts) : key.ToString();
    }

    private string TruncateName(string name, int maxLength)
    {
        if (string.IsNullOrEmpty(name))
            return "";
        return name.Length <= maxLength ? name : name[..maxLength];
    }

    private record StanceBarInfo(string Name, int BaseSlot);

