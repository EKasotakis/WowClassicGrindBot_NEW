@implements IDisposable
@inject KeyBindingsReader keyBindingsReader
@inject ActionBarTextureReader actionBarTextureReader
@inject ActionBarSlotValidator actionBarSlotValidator
@inject SpellBookReader spellBookReader
@inject IBotController botController
@inject Core.Database.IconDB iconDB
@inject PlayerReader playerReader
@inject ILoggerFactory logFactory
@inject BagReader bagReader
@inject EquipmentReader equipmentReader
@inject ExecGameCommand exec
@inject AddonConfigurator addonConfigurator
@inject WowProcessInput wowInput
@inject IAddonReader addonReader
@inject ActionBarCostReader actionBarCostReader
@inject ActionBarCooldownReader actionBarCooldownReader
@inject ActionBarBits<IUsableAction> usableAction
@inject ActionBarBits<ICurrentAction> currentAction

@if (botController.ClassConfig == null)
{
    <div class="card mt-1">
        <div class="card-header">
            Keyboard Bindings
        </div>
        <div class="card-body">
            <div class="alert alert-info">
                Please load a class profile first to view key bindings.
            </div>
        </div>
    </div>
}
else
{
<div class="card mt-1">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>Keyboard Bindings</span>
        <div class="d-flex align-items-center">
            @if (validationSummary.MissingCount > 0)
            {
                <span class="badge bg-warning me-1">@validationSummary.MissingCount missing</span>
            }
            @if (validationSummary.BoundCount > 0)
            {
                <span class="badge bg-success me-1">@validationSummary.BoundCount OK</span>
            }
            <span class="badge @(keyBindingsReader.IsInitialized ? "bg-info" : "bg-secondary") me-2">
                @(keyBindingsReader.IsInitialized ? $"{keyBindingsReader.Count} in-game" : "Loading...")
            </span>
            @if (HasMissingActionBarBindings())
            {
                <button class="btn btn-sm btn-outline-warning me-1" @onclick="SetupBindings" title="Run /@addonConfigurator.Config.CommandBindings to set default action bar key bindings">
                    Setup Bindings
                </button>
            }
            @if (HasMissingCustomActions())
            {
                <button class="btn btn-sm btn-outline-warning me-1" @onclick="SetupActions" title="Run /@addonConfigurator.Config.CommandActions to create custom action buttons">
                    Setup Actions
                </button>
            }
            <button class="btn btn-sm btn-primary me-1" @onclick="SyncActionBar" disabled="@(actionBarPopulator == null)">
                <span>Sync Actionbar</span>
            </button>
            <button class="btn btn-sm btn-primary" @onclick="InitState">
                <span>Init State</span>
            </button>
        </div>
    </div>
    <div class="card-body">
        @if (validationSummary.MissingCount > 0)
        {
            <div class="alert alert-warning mb-2 p-2">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <strong>Missing key bindings!</strong> Set these bindings in-game or run <code>/@addonConfigurator.Config.CommandBindings</code> to apply defaults.
                    </div>
                    <button class="btn btn-sm btn-outline-warning" type="button"
                            data-bs-toggle="collapse" data-bs-target="#mismatchDetails">
                        Details
                    </button>
                </div>
                <div class="collapse mt-2" id="mismatchDetails">
                    <table class="table table-sm table-dark mb-0">
                        <thead>
                            <tr>
                                <th>Binding</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var issue in GetValidationIssues())
                            {
                                <tr>
                                    <td>@issue.BindingId.ToStringF()</td>
                                    <td><span class="badge bg-warning">Not bound in-game</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        <div class="keyboard-wrapper">
        <div class="keyboard-layout">
        <div class="keyboard-container">
            @* Function Row - Slots 61-72 *@
            <div class="keyboard-row">
                <div class="key key-sm">Esc</div>
                @for (int i = 1; i <= 12; i++)
                {
                    var fKey = GetConsoleKey($"F{i}");
                    int slot = 60 + i;
                    var action = GetActionForSlot(slot);
                    var iconUrl = GetIconUrl(slot);
                    <div class="key key-sm @GetKeyClass(fKey) @GetActionClass(action, slot)" title="@GetCombinedTooltip(fKey, slot, action)">
                        @if (iconUrl != null)
                        {
                            <img src="@iconUrl" class="key-icon" alt="" />
                        }
                        else
                        {
                            <span>F@(i)</span>
                            @if (action != null)
                            {
                                <div class="key-spell">@TruncateName(action.Name, 6)</div>
                            }
                            else if (GetBindingLabel(fKey) is string label)
                            {
                                <div class="key-binding">@label</div>
                            }
                        }
                    </div>
                }
            </div>

            @* Number Row - Slots 1-12 *@
            <div class="keyboard-row">
                <div class="key">`</div>
                @foreach (var key in numberRowKeys)
                {
                    var consoleKey = GetConsoleKey(key);
                    int slot = GetMainBarSlot(key);
                    var action = GetActionForSlot(slot);
                    var iconUrl = GetIconUrl(slot);
                    <div class="key @GetKeyClass(consoleKey) @GetActionClass(action, slot)" title="@GetCombinedTooltip(consoleKey, slot, action)">
                        @if (iconUrl != null)
                        {
                            <img src="@iconUrl" class="key-icon" alt="" />
                        }
                        else
                        {
                            <span>@key</span>
                            @if (action != null)
                            {
                                <div class="key-spell">@TruncateName(action.Name, 6)</div>
                            }
                            else if (GetBindingLabel(consoleKey) is string label)
                            {
                                <div class="key-binding">@label</div>
                            }
                        }
                    </div>
                }
                <div class="key key-wide">Bksp</div>
            </div>

            @* QWERTY Row *@
            <div class="keyboard-row">
                <div class="key key-tab">Tab</div>
                @foreach (var key in qwertyRowKeys)
                {
                    var consoleKey = GetConsoleKey(key);
                    <div class="key @GetKeyClass(consoleKey)" title="@GetKeyTooltip(consoleKey)">
                        @key
                        @if (GetBindingLabel(consoleKey) is string label)
                        {
                            <div class="key-binding">@label</div>
                        }
                    </div>
                }
            </div>

            @* ASDF Row *@
            <div class="keyboard-row">
                <div class="key key-caps">Caps</div>
                @foreach (var key in asdfRowKeys)
                {
                    var consoleKey = GetConsoleKey(key);
                    <div class="key @GetKeyClass(consoleKey)" title="@GetKeyTooltip(consoleKey)">
                        @key
                        @if (GetBindingLabel(consoleKey) is string label)
                        {
                            <div class="key-binding">@label</div>
                        }
                    </div>
                }
                <div class="key key-enter">Enter</div>
            </div>

            @* ZXCV Row *@
            <div class="keyboard-row">
                <div class="key key-shift">Shift</div>
                @foreach (var key in zxcvRowKeys)
                {
                    var consoleKey = GetConsoleKey(key);
                    <div class="key @GetKeyClass(consoleKey)" title="@GetKeyTooltip(consoleKey)">
                        @key
                        @if (GetBindingLabel(consoleKey) is string label)
                        {
                            <div class="key-binding">@label</div>
                        }
                    </div>
                }
                <div class="key key-shift">Shift</div>
            </div>

            @* Space Row *@
            <div class="keyboard-row">
                <div class="key key-ctrl">Ctrl</div>
                <div class="key key-sm">Win</div>
                <div class="key key-sm">Alt</div>
                @{
                    var spaceKey = ConsoleKey.Spacebar;
                }
                <div class="key key-space @GetKeyClass(spaceKey)" title="@GetKeyTooltip(spaceKey)">
                    Space
                    @if (GetBindingLabel(spaceKey) is string spaceLabel)
                    {
                        <div class="key-binding">@spaceLabel</div>
                    }
                </div>
                <div class="key key-sm">Alt</div>
                <div class="key key-sm">Win</div>
                <div class="key key-ctrl">Ctrl</div>
            </div>
        </div>

        @* Navigation Keys *@
        <div class="keyboard-container mt-2">
            <div class="keyboard-row">
                @{
                    var insertKey = ConsoleKey.Insert;
                    var homeKey = ConsoleKey.Home;
                    var pageUpKey = ConsoleKey.PageUp;
                }
                <div class="key key-nav @GetKeyClass(insertKey)" title="@GetKeyTooltip(insertKey)">
                    Ins
                    @if (GetBindingLabel(insertKey) is string insLabel)
                    {
                        <div class="key-binding">@insLabel</div>
                    }
                </div>
                <div class="key key-nav @GetKeyClass(homeKey)" title="@GetKeyTooltip(homeKey)">
                    Home
                    @if (GetBindingLabel(homeKey) is string homeLabel)
                    {
                        <div class="key-binding">@homeLabel</div>
                    }
                </div>
                <div class="key key-nav @GetKeyClass(pageUpKey)" title="@GetKeyTooltip(pageUpKey)">
                    PgUp
                    @if (GetBindingLabel(pageUpKey) is string pgUpLabel)
                    {
                        <div class="key-binding">@pgUpLabel</div>
                    }
                </div>
            </div>
            <div class="keyboard-row">
                @{
                    var deleteKey = ConsoleKey.Delete;
                    var endKey = ConsoleKey.End;
                    var pageDownKey = ConsoleKey.PageDown;
                }
                <div class="key key-nav @GetKeyClass(deleteKey)" title="@GetKeyTooltip(deleteKey)">
                    Del
                    @if (GetBindingLabel(deleteKey) is string delLabel)
                    {
                        <div class="key-binding">@delLabel</div>
                    }
                </div>
                <div class="key key-nav @GetKeyClass(endKey)" title="@GetKeyTooltip(endKey)">
                    End
                    @if (GetBindingLabel(endKey) is string endLabel)
                    {
                        <div class="key-binding">@endLabel</div>
                    }
                </div>
                <div class="key key-nav @GetKeyClass(pageDownKey)" title="@GetKeyTooltip(pageDownKey)">
                    PgDn
                    @if (GetBindingLabel(pageDownKey) is string pgDnLabel)
                    {
                        <div class="key-binding">@pgDnLabel</div>
                    }
                </div>
            </div>
        </div>

        @* Numpad - Slots 49-58 *@
        <div class="keyboard-container mt-2">
            <div class="keyboard-row">
                @for (int i = 7; i <= 9; i++)
                {
                    var numKey = GetNumpadKey(i);
                    int slot = GetNumpadSlot(i);
                    var action = GetActionForSlot(slot);
                    var iconUrl = GetIconUrl(slot);
                    <div class="key key-num @GetKeyClass(numKey) @GetActionClass(action, slot)" title="@GetCombinedTooltip(numKey, slot, action)">
                        @if (iconUrl != null)
                        {
                            <img src="@iconUrl" class="key-icon" alt="" />
                        }
                        else
                        {
                            <span>@i</span>
                            @if (action != null)
                            {
                                <div class="key-spell">@TruncateName(action.Name, 5)</div>
                            }
                            else if (GetBindingLabel(numKey) is string label)
                            {
                                <div class="key-binding">@label</div>
                            }
                        }
                    </div>
                }
                @{
                    var addKey = ConsoleKey.Add;
                }
                <div class="key key-num @GetKeyClass(addKey)" title="@GetKeyTooltip(addKey)">
                    +
                    @if (GetBindingLabel(addKey) is string addLabel)
                    {
                        <div class="key-binding">@addLabel</div>
                    }
                </div>
            </div>
            <div class="keyboard-row">
                @for (int i = 4; i <= 6; i++)
                {
                    var numKey = GetNumpadKey(i);
                    int slot = GetNumpadSlot(i);
                    var action = GetActionForSlot(slot);
                    var iconUrl = GetIconUrl(slot);
                    <div class="key key-num @GetKeyClass(numKey) @GetActionClass(action, slot)" title="@GetCombinedTooltip(numKey, slot, action)">
                        @if (iconUrl != null)
                        {
                            <img src="@iconUrl" class="key-icon" alt="" />
                        }
                        else
                        {
                            <span>@i</span>
                            @if (action != null)
                            {
                                <div class="key-spell">@TruncateName(action.Name, 5)</div>
                            }
                            else if (GetBindingLabel(numKey) is string label)
                            {
                                <div class="key-binding">@label</div>
                            }
                        }
                    </div>
                }
                @{
                    var subKey = ConsoleKey.Subtract;
                }
                <div class="key key-num @GetKeyClass(subKey)" title="@GetKeyTooltip(subKey)">
                    -
                    @if (GetBindingLabel(subKey) is string subLabel)
                    {
                        <div class="key-binding">@subLabel</div>
                    }
                </div>
            </div>
            <div class="keyboard-row">
                @for (int i = 1; i <= 3; i++)
                {
                    var numKey = GetNumpadKey(i);
                    int slot = GetNumpadSlot(i);
                    var action = GetActionForSlot(slot);
                    var iconUrl = GetIconUrl(slot);
                    <div class="key key-num @GetKeyClass(numKey) @GetActionClass(action, slot)" title="@GetCombinedTooltip(numKey, slot, action)">
                        @if (iconUrl != null)
                        {
                            <img src="@iconUrl" class="key-icon" alt="" />
                        }
                        else
                        {
                            <span>@i</span>
                            @if (action != null)
                            {
                                <div class="key-spell">@TruncateName(action.Name, 5)</div>
                            }
                            else if (GetBindingLabel(numKey) is string label)
                            {
                                <div class="key-binding">@label</div>
                            }
                        }
                    </div>
                }
                @{
                    var mulKey = ConsoleKey.Multiply;
                }
                <div class="key key-num @GetKeyClass(mulKey)" title="@GetKeyTooltip(mulKey)">
                    *
                    @if (GetBindingLabel(mulKey) is string mulLabel)
                    {
                        <div class="key-binding">@mulLabel</div>
                    }
                </div>
            </div>
            <div class="keyboard-row">
                @{
                    var num0Key = ConsoleKey.NumPad0;
                    var divKey = ConsoleKey.Divide;
                    int num0Slot = GetNumpadSlot(0);
                    var num0Action = GetActionForSlot(num0Slot);
                    var num0IconUrl = GetIconUrl(num0Slot);
                }
                <div class="key key-num key-num0 @GetKeyClass(num0Key) @GetActionClass(num0Action, num0Slot)" title="@GetCombinedTooltip(num0Key, num0Slot, num0Action)">
                    @if (num0IconUrl != null)
                    {
                        <img src="@num0IconUrl" class="key-icon" alt="" />
                    }
                    else
                    {
                        <span>0</span>
                        @if (num0Action != null)
                        {
                            <div class="key-spell">@TruncateName(num0Action.Name, 8)</div>
                        }
                        else if (GetBindingLabel(num0Key) is string num0Label)
                        {
                            <div class="key-binding">@num0Label</div>
                        }
                    }
                </div>
                <div class="key key-num @GetKeyClass(divKey)" title="@GetKeyTooltip(divKey)">
                    /
                    @if (GetBindingLabel(divKey) is string divLabel)
                    {
                        <div class="key-binding">@divLabel</div>
                    }
                </div>
            </div>
        </div>
        </div> @* keyboard-layout *@

        @* Stance/Form Bars *@
        @if (GetStanceBars() is var stanceBars && stanceBars.Length > 0)
        {
            <div class="stance-bars mt-3">
                <h6 class="text-muted mb-2">Stance/Form Bars</h6>
                <div class="d-flex flex-wrap gap-3">
                    @foreach (var stance in stanceBars)
                    {
                        <div class="stance-bar-section">
                            <div class="stance-bar-label">@stance.Name</div>
                            <div class="keyboard-container">
                                <div class="keyboard-row">
                                    @for (int i = 1; i <= 12; i++)
                                    {
                                        int slot = stance.BaseSlot + i;
                                        var action = GetActionForSlot(slot);
                                        var iconUrl = GetIconUrl(slot);
                                        var hasTexture = actionBarTextureReader.TryGetTexture(slot, out int textureId);
                                        <div class="key key-sm @GetSlotValidationClass(slot, action)" title="@GetStanceSlotTooltip(slot, action)">
                                            @if (iconUrl != null)
                                            {
                                                <img src="@iconUrl" class="key-icon" alt="" />
                                            }
                                            else if (action != null)
                                            {
                                                <span class="key-slot">@i</span>
                                                <div class="key-spell">@TruncateName(action.Name, 5)</div>
                                            }
                                            else if (hasTexture && textureId > 0)
                                            {
                                                <span class="key-slot">@i</span>
                                                <div class="key-spell">tex:@textureId</div>
                                            }
                                            else
                                            {
                                                <span class="key-slot-empty">@i</span>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
        </div> @* keyboard-wrapper *@

        @* Legend *@
        <div class="mt-3">
            <span class="badge bg-success me-2">Bound in-game</span>
            <span class="badge bg-warning text-dark me-2">Not bound</span>
            <span class="badge bg-info me-2">In-game (extra)</span>
            <span class="badge bg-primary me-2">Configured Action</span>
            <span class="badge" style="background:#3a3a5e">In-game Action</span>
        </div>

        @* Missing Spells Section *@
        @{
            var actionBarIssues = GetActionBarIssues();
            var resolvableIssues = actionBarIssues.Where(i => i.CanResolve).ToList();
            var hardErrors = actionBarIssues.Where(i => !i.CanResolve).ToList();
        }
        @if (actionBarIssues.Count > 0)
        {
            <div class="mt-3 border-top pt-3">
                <h6 class="text-muted mb-2">Action Bar Issues</h6>

                @if (resolvableIssues.Count > 0)
                {
                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="text-warning">Resolvable (@resolvableIssues.Count)</span>
                            @if (resolvableIssues.Count > 1)
                            {
                                <button class="btn btn-sm btn-outline-success" @onclick="ResolveAllActionBarIssues">
                                    Resolve All
                                </button>
                            }
                        </div>
                        <table class="table table-sm table-dark mb-0">
                            <thead>
                                <tr>
                                    <th>Spell</th>
                                    <th>Slot</th>
                                    <th>Status</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var issue in resolvableIssues)
                                {
                                    <tr>
                                        <td>@issue.SpellName</td>
                                        <td>@issue.Slot</td>
                                        <td>
                                            @if (issue.Status == SlotValidationStatus.EmptySlot)
                                            {
                                                <span class="badge bg-warning text-dark">Empty</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">Mismatch</span>
                                            }
                                        </td>
                                        <td>
                                            <button class="btn btn-xs btn-outline-success" @onclick="() => ResolveActionBarIssue(issue)">
                                                Place
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

                @if (hardErrors.Count > 0)
                {
                    <div class="mb-2">
                        <span class="text-danger">Manual Resolution Required (@hardErrors.Count)</span>
                        <table class="table table-sm table-dark mb-0 mt-2">
                            <thead>
                                <tr>
                                    <th>Spell</th>
                                    <th>Issue</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var issue in hardErrors)
                                {
                                    <tr>
                                        <td>@issue.SpellName</td>
                                        <td><span class="text-danger">No slot configured - add Key or Slot to profile</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        }

        @* All Bindings Section *@
        <div class="mt-3 border-top pt-3">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h6 class="text-muted mb-0">All In-Game Bindings (@keyBindingsReader.Count)</h6>
                <button class="btn btn-sm btn-outline-secondary" type="button"
                        data-bs-toggle="collapse" data-bs-target="#allBindingsSection">
                    Toggle
                </button>
            </div>
            <div class="collapse" id="allBindingsSection">
                <table class="table table-sm table-dark mb-0">
                    <thead>
                        <tr>
                            <th>Binding ID</th>
                            <th>Keys (click to test)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var bindingId in GetAllBindingIds())
                        {
                            var hasKey1 = keyBindingsReader.TryGetBinding(bindingId, out var key1, out var mod1);
                            var hasKey2 = keyBindingsReader.TryGetSecondaryBinding(bindingId, out var key2, out var mod2);

                            @if (hasKey1 || hasKey2)
                            {
                                <tr>
                                    <td>
                                        <span class="@GetBindingIdClass(bindingId)">@bindingId.ToStringF()</span>
                                    </td>
                                    <td>
                                        @if (hasKey1)
                                        {
                                            <button class="btn btn-xs btn-outline-info me-1"
                                                    @onclick="() => TestKey(key1, mod1)"
                                                    title="Send @FormatKeyWithModifier(key1, mod1) to game">
                                                @FormatKeyWithModifier(key1, mod1)
                                            </button>
                                        }
                                        @if (hasKey2)
                                        {
                                            <button class="btn btn-xs btn-outline-secondary"
                                                    @onclick="() => TestKey(key2, mod2)"
                                                    title="Send @FormatKeyWithModifier(key2, mod2) to game">
                                                @FormatKeyWithModifier(key2, mod2)
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
}

<style>
    .keyboard-wrapper {
        width: 100%;
        overflow-x: auto;
    }

    .keyboard-layout {
        display: flex;
        flex-wrap: wrap;
        gap: 15px;
        transform-origin: top left;
    }

    .keyboard-container {
        display: inline-block;
        background: #2d2d2d;
        padding: 10px;
        border-radius: 8px;
        flex-shrink: 0;
    }

    .keyboard-row {
        display: flex;
        gap: 4px;
        margin-bottom: 4px;
    }

    .key {
        min-width: 40px;
        height: 40px;
        background: #404040;
        border: 1px solid #555;
        border-radius: 4px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        color: #ccc;
        position: relative;
        cursor: default;
    }

    .key:hover {
        background: #505050;
    }

    .key-binding {
        font-size: 8px;
        color: #aaa;
        max-width: 38px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .key-bound {
        background: #1a5c1a;
        border-color: #2d8a2d;
    }

    .key-mismatch {
        background: #8a2d2d;
        border-color: #b33;
    }

    .key-expected {
        background: #6e5c1a;
        border-color: #b9a029;
    }

    .key-ingame {
        background: #1a4a6e;
        border-color: #2980b9;
    }

    .key-sm { min-width: 35px; }
    .key-wide { min-width: 60px; }
    .key-tab { min-width: 55px; }
    .key-caps { min-width: 65px; }
    .key-enter { min-width: 75px; }
    .key-shift { min-width: 85px; }
    .key-ctrl { min-width: 50px; }
    .key-space { min-width: 200px; }
    .key-nav { min-width: 45px; }
    .key-num { min-width: 40px; }
    .key-num0 { min-width: 84px; }

    /* Action Bar Spell on Key */
    .key-spell {
        font-size: 8px;
        color: #7cb3d9;
        max-width: 38px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .key-action {
        background: #2a4a5e;
        border-color: #3a6a8e;
    }

    .key-ingame-action {
        background: #3a3a5e;
        border-color: #5a5a8e;
