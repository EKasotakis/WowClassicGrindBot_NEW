        return parts.Count > 0 ? string.Join(", ", parts) : "";
    }

    private string GetCombinedTooltip(ConsoleKey key, int slot, KeyAction? action)
    {
        var parts = new List<string>();

        // Show what's bound to this key in-game
        if (actualBindings.TryGetValue(key, out var primary))
        {
            parts.Add($"Binding: {primary.ToStringF()}");
        }

        // Show slot info
        if (action != null)
        {
            parts.Add($"Slot {slot}: {action.Name}");
