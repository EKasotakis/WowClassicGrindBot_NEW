    private string GetStanceSlotTooltip(int slot, KeyAction? action)
    {
        var parts = new List<string> { $"Slot {slot}" };

        if (actionBarTextureReader.TryGetTexture(slot, out var textureId) && textureId > 0)
        {
            parts.Add($"Texture: {textureId}");

            // Try to get spell names for this texture
            var spellNames = iconDB.GetSpellNamesForDisplay(textureId);
            if (spellNames.Length > 0)
            {
                parts.Add($"Spells: {string.Join(", ", spellNames.Take(3))}");
            }
        }

        if (action != null)
        {
            parts.Add($"Config: {action.Name}");

            // Show validation status
            var status = GetSlotValidationStatus(slot, action);
            parts.Add($"Status: {status}");

            // Add slot-based reader info (cost, cooldown, usable status)
            string slotInfo = GetSlotInfo(action);
            if (!string.IsNullOrEmpty(slotInfo))
                parts.Add(slotInfo);
        }

        return string.Join(" | ", parts);
    }

    private string GetSlotValidationClass(int slot, KeyAction? action)
    {
        if (action == null)
        {
            // No configured action - show if there's something in-game
            if (actionBarTextureReader.HasAction(slot))
                return "key-ingame-action";
            return "";
        }

        // Has configured action - check validation
        var status = GetSlotValidationStatus(slot, action);
        return status switch
        {
            "Valid" => "key-valid",
            "Macro" => "key-action",      // Macros skip validation, show as configured
            "Item" => "key-action",        // Items skip validation, show as configured
            "Unknown" => "key-action",     // Unknown texture (item/macro), show as configured
            "Empty" => "key-empty-warning",
            "Mismatch" => "key-mismatch",
            _ => "key-action"
        };
    }

    private string GetSlotValidationStatus(int slot, KeyAction action)
    {
        // Use centralized validation from ActionBarSlotValidator
        SlotValidationStatus status = actionBarSlotValidator.Validate(action);

        return status switch
        {
            SlotValidationStatus.Valid => "Valid",
            SlotValidationStatus.NotOnActionBar => "Valid", // Base actions without slots
            SlotValidationStatus.EmptySlot => "Empty",
            SlotValidationStatus.Mismatch => "Mismatch",
            SlotValidationStatus.UnknownTexture => "Unknown",
            _ => "Valid"
        };
    }

    private string? GetIconUrl(int slot)
    {
        if (slot <= 0)
            return null;

        if (!actionBarTextureReader.TryGetTexture(slot, out int textureId) || textureId <= 0)
            return null;

        return iconDB.GetIconUrl(textureId, 36);
    }

    private void BuildExpectedBindings()
    {
        // First, add defaults from KeyBindingDefaults
        foreach (var kvp in KeyBindingDefaults.Bindings)
        {
            var binding = kvp.Value;
            expectedBindings[binding.ConsoleKey] = binding.BindingID;
            expectedByBindingId[binding.BindingID] = binding.ConsoleKey;
        }

        // Then override with ClassConfig key actions (these take precedence)
        foreach (var keyAction in GetAllKeyActions())
        {
            if (keyAction.BindingID != BindingID.None && keyAction.ConsoleKey != ConsoleKey.NoName)
            {
                // Remove old key mapping if the binding moved to a different key
                if (expectedByBindingId.TryGetValue(keyAction.BindingID, out var oldKey) && oldKey != keyAction.ConsoleKey)
                {
                    expectedBindings.Remove(oldKey);
                }

                expectedBindings[keyAction.ConsoleKey] = keyAction.BindingID;
                expectedByBindingId[keyAction.BindingID] = keyAction.ConsoleKey;
            }
        }
    }

    private void BuildActualBindings()
    {
        foreach (var kvp in keyBindingsReader.Bindings)
        {
            // kvp.Value is now (ConsoleKey Key, ModifierKey Modifier)
            actualBindings[kvp.Value.Key] = kvp.Key;
        }
        foreach (var kvp in keyBindingsReader.SecondaryBindings)
        {
            actualSecondaryBindings[kvp.Value.Key] = kvp.Key;
        }
    }

    private void BuildValidationSummary()
    {
        validationSummary = new ValidationSummary();
        validationIssues.Clear();

        // Check all required BindingIDs - we only care if they exist in-game, not what key they're bound to
        foreach (var bindingId in expectedByBindingId.Keys)
        {
            // Check if the binding exists in-game (primary or secondary)
            if (keyBindingsReader.TryGetBinding(bindingId, out _, out _) ||
                keyBindingsReader.TryGetSecondaryBinding(bindingId, out _, out _))
            {
                // Binding exists - any key+modifier is fine
                validationSummary.BoundCount++;
            }
            else
            {
                // Binding not found in-game - warn user to set it
                validationSummary.MissingCount++;
                validationIssues.Add(new ValidationIssue(bindingId, true));
            }
        }
    }

    private IEnumerable<ValidationIssue> GetValidationIssues() => validationIssues;

    private IEnumerable<KeyAction> GetAllKeyActions()
    {
        var config = botController.ClassConfig!;
        yield return config.Jump;
        yield return config.Interact;
        yield return config.InteractMouseOver;
        yield return config.Approach;
        yield return config.AutoAttack;
        yield return config.TargetLastTarget;
        yield return config.StandUp;
        yield return config.ClearTarget;
        yield return config.StopAttack;
        yield return config.TargetNearestTarget;
        yield return config.TargetTargetOfTarget;
        yield return config.TargetPet;
        yield return config.PetAttack;
        yield return config.TargetFocus;
        yield return config.FollowTarget;
        yield return config.Mount;
    }

    private ConsoleKey GetConsoleKey(string key)
    {
        return key switch
        {
            "1" => ConsoleKey.D1, "2" => ConsoleKey.D2, "3" => ConsoleKey.D3,
            "4" => ConsoleKey.D4, "5" => ConsoleKey.D5, "6" => ConsoleKey.D6,
            "7" => ConsoleKey.D7, "8" => ConsoleKey.D8, "9" => ConsoleKey.D9,
            "0" => ConsoleKey.D0, "-" => ConsoleKey.OemMinus, "=" => ConsoleKey.OemPlus,
            "F1" => ConsoleKey.F1, "F2" => ConsoleKey.F2, "F3" => ConsoleKey.F3,
            "F4" => ConsoleKey.F4, "F5" => ConsoleKey.F5, "F6" => ConsoleKey.F6,
            "F7" => ConsoleKey.F7, "F8" => ConsoleKey.F8, "F9" => ConsoleKey.F9,
            "F10" => ConsoleKey.F10, "F11" => ConsoleKey.F11, "F12" => ConsoleKey.F12,
            _ when key.Length == 1 && char.IsLetter(key[0]) =>
                Enum.Parse<ConsoleKey>(key.ToUpper()),
            "[" => ConsoleKey.Oem4, "]" => ConsoleKey.Oem6, "\\" => ConsoleKey.Oem5,
            ";" => ConsoleKey.Oem1, "'" => ConsoleKey.Oem7,
            "," => ConsoleKey.OemComma, "." => ConsoleKey.OemPeriod, "/" => ConsoleKey.Oem2,
            _ => ConsoleKey.NoName
        };
    }

    private ConsoleKey GetNumpadKey(int num)
    {
        return num switch
        {
            0 => ConsoleKey.NumPad0, 1 => ConsoleKey.NumPad1, 2 => ConsoleKey.NumPad2,
            3 => ConsoleKey.NumPad3, 4 => ConsoleKey.NumPad4, 5 => ConsoleKey.NumPad5,
            6 => ConsoleKey.NumPad6, 7 => ConsoleKey.NumPad7, 8 => ConsoleKey.NumPad8,
            9 => ConsoleKey.NumPad9, _ => ConsoleKey.NoName
        };
    }

    private string GetKeyClass(ConsoleKey key)
    {
        bool hasActualPrimary = actualBindings.ContainsKey(key);
        bool hasActualSecondary = actualSecondaryBindings.ContainsKey(key);
        bool hasActual = hasActualPrimary || hasActualSecondary;

        if (hasActual)
        {
            // Key has an in-game binding
            var bindingId = hasActualPrimary ? actualBindings[key] : actualSecondaryBindings[key];

            // Is this a required binding from our config/defaults?
            if (expectedByBindingId.ContainsKey(bindingId))
            {
                return "key-bound"; // Green: required binding is set in-game
            }
            else
            {
                return "key-ingame"; // Blue: in-game binding not in our required list
            }
        }
        else if (expectedBindings.ContainsKey(key))
        {
            // This key is expected to have a binding, but doesn't in-game
            var expectedBindingId = expectedBindings[key];
            if (!keyBindingsReader.TryGetBinding(expectedBindingId, out _, out _) &&
                !keyBindingsReader.TryGetSecondaryBinding(expectedBindingId, out _, out _))
            {
                return "key-expected"; // Yellow: binding not found in-game at all
            }
        }

        return "";
    }

    private string? GetBindingLabel(ConsoleKey key)
    {
        if (expectedBindings.TryGetValue(key, out var bindingId))
        {
            return GetShortName(bindingId);
        }
        if (actualBindings.TryGetValue(key, out bindingId))
        {
            return GetShortName(bindingId);
        }
        return null;
    }

    private string GetShortName(BindingID bindingId)
    {
        return bindingId switch
        {
            BindingID.JUMP => "Jump",
            BindingID.INTERACTTARGET => "Interact",
            BindingID.INTERACTMOUSEOVER => "IntMO",
            BindingID.TARGETLASTTARGET => "LastTgt",
            BindingID.SITORSTAND => "Sit",
            BindingID.STOPATTACK => "Stop",
            BindingID.TARGETNEARESTENEMY => "TabTgt",
            BindingID.ASSISTTARGET => "Assist",
            BindingID.TARGETPET => "TgtPet",
            BindingID.PETATTACK => "PetAtk",
            BindingID.TARGETFOCUS => "Focus",
            BindingID.FOLLOWTARGET => "Follow",
            BindingID.STARTATTACK => "Attack",
            BindingID.MOVEFORWARD => "Fwd",
            BindingID.MOVEBACKWARD => "Back",
            BindingID.STRAFELEFT => "StrfL",
            BindingID.STRAFERIGHT => "StrfR",
            BindingID.TURNLEFT => "TurnL",
            BindingID.TURNRIGHT => "TurnR",
            _ => bindingId.ToStringF()
        };
    }

    private string GetKeyTooltip(ConsoleKey key)
    {
        var parts = new List<string>();

        // Show what's bound to this key in-game
        if (actualBindings.TryGetValue(key, out var primary))
        {
            // Get the modifier for this binding
            if (keyBindingsReader.Bindings.Values.FirstOrDefault(b => b.Key == key) is var binding && binding.Key != ConsoleKey.NoName)
            {
                var modPrefix = binding.Modifier != ModifierKey.None ? $"{binding.Modifier.ToPrefix()}" : "";
                parts.Add($"In-Game: {modPrefix}{primary.ToStringF()}");
            }
            else
            {
                parts.Add($"In-Game: {primary.ToStringF()}");
            }
        }
        if (actualSecondaryBindings.TryGetValue(key, out var secondary))
        {
            parts.Add($"Secondary: {secondary.ToStringF()}");
        }

        // If this key is in our defaults but not bound, note that
        if (expectedBindings.TryGetValue(key, out var expectedBindingId))
        {
            if (!keyBindingsReader.TryGetBinding(expectedBindingId, out _, out _) &&
                !keyBindingsReader.TryGetSecondaryBinding(expectedBindingId, out _, out _))
            {
                parts.Add($"Default: {expectedBindingId.ToStringF()} (NOT BOUND)");
            }
        }

        return parts.Count > 0 ? string.Join(" | ", parts) : key.ToString();
    }

    #region Bindings List Helpers

    /// <summary>
    /// Returns all BindingID values that are tracked by the addon.
    /// </summary>
    private IEnumerable<BindingID> GetAllBindingIds()
    {
        // Return all BindingIDs that are in either primary or secondary bindings
        var allIds = new HashSet<BindingID>();

        foreach (var kvp in keyBindingsReader.Bindings)
            allIds.Add(kvp.Key);

        foreach (var kvp in keyBindingsReader.SecondaryBindings)
            allIds.Add(kvp.Key);

        // Sort by category for better display
        return allIds.OrderBy(b => GetBindingCategory(b)).ThenBy(b => b.ToString());
    }

    private int GetBindingCategory(BindingID bindingId)
    {
        var name = bindingId.ToString();
        if (name.StartsWith("MOVE") || name.StartsWith("STRAFE") || name.StartsWith("TURN") || name == "JUMP" || name == "SITORSTAND")
            return 0; // Movement
        if (name.StartsWith("TARGET") || name.StartsWith("ASSIST") || name.StartsWith("FOCUS"))
            return 1; // Targeting
        if (name.StartsWith("ACTIONBUTTON"))
            return 2; // Main action bar
        if (name.StartsWith("MULTIACTIONBAR2"))
            return 3; // Bottom right bar
        if (name.StartsWith("MULTIACTIONBAR1"))
            return 4; // Bottom left bar
        if (name.StartsWith("CUSTOM_"))
            return 5; // Custom actions
        if (name.StartsWith("PET") || name.StartsWith("INTERACT") || name.StartsWith("FOLLOW"))
            return 6; // Interaction
        return 99; // Other
    }

    private string GetBindingIdClass(BindingID bindingId)
    {
        var name = bindingId.ToString();
        if (name.StartsWith("CUSTOM_"))
            return "text-warning";
        if (name.StartsWith("ACTIONBUTTON"))
            return "text-info";
        if (name.StartsWith("MULTIACTIONBAR"))
            return "text-success";
        return "";
    }

    private string FormatKeyWithModifier(ConsoleKey key, ModifierKey modifier)
    {
        var modPrefix = modifier != ModifierKey.None ? modifier.ToPrefix() : "";
        return $"{modPrefix}{key}";
    }

    private void TestKey(ConsoleKey key, ModifierKey modifier)
    {
        // Send the key press to the game
        if (modifier != ModifierKey.None)
        {
            wowInput.PressRandomWithModifier(key, modifier, 50);
        }
        else
        {
            wowInput.PressRandom(key, 50);
        }
    }

    #endregion
