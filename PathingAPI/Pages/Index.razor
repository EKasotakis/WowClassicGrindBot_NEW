    private readonly record struct Route(string Name, string Href, string ReverseHref = "");

    private static Route WithReverse(string name, string href) => new(name, href, href + "&reverse=true");

    /// <summary>WorldRoute: coordinates + mapId</summary>
    private static string WR(
        double x1, double y1, double z1,
        double x2, double y2, double z2,
        int mapId, bool reverse = false) =>
        reverse
            ? FormattableString.Invariant($"api/PPather/WorldRoute?x1={x1}&y1={y1}&z1={z1}&x2={x2}&y2={y2}&z2={z2}&mapid={mapId}&reverse=true")
            : FormattableString.Invariant($"api/PPather/WorldRoute?x1={x1}&y1={y1}&z1={z1}&x2={x2}&y2={y2}&z2={z2}&mapid={mapId}");

    /// <summary>WorldRoute2: coordinates + uiMap</summary>
    private static string WR2(
        double x1, double y1, double z1,
        double x2, double y2, double z2,
        int uiMap, int? mapId = null, bool startIndoors = false) =>
        mapId.HasValue
            ? FormattableString.Invariant($"api/PPather/WorldRoute2?x1={x1}&y1={y1}&z1={z1}&x2={x2}&y2={y2}&z2={z2}&uimap={uiMap}&mapid={mapId.Value}&startindoors={startIndoors.ToString().ToLowerInvariant()}")
            : FormattableString.Invariant($"api/PPather/WorldRoute2?x1={x1}&y1={y1}&z1={z1}&x2={x2}&y2={y2}&z2={z2}&uimap={uiMap}&startindoors={startIndoors.ToString().ToLowerInvariant()}");

    /// <summary>MapRoute: uiMap coordinates</summary>
    private static string MR(
        int uiMap1, double x1, double y1,
        int uiMap2, double x2, double y2) =>
        FormattableString.Invariant($"api/PPather/MapRoute?uimap1={uiMap1}&x1={x1}&y1={y1}&uimap2={uiMap2}&x2={x2}&y2={y2}");

