@page "/"

<style>
    #bottomOverlay {
        position: fixed;
        left: 0;
        width: 250px;
        height: calc(57% - 15px); /* Subtract 15px from the bottom */
        bottom: 15px; /* Fixed bottom */
        top: 430px; /* Use custom top position */
        overflow-y: auto;
        background-color: rgba(0, 0, 0, 0.8);
        z-index: 1000;
        padding: 10px 0; /* Add padding for spacing */
    }

        #bottomOverlay a {
            display: block;
            height: 30px; /* Explicit height */
            line-height: 30px; /* Vertically center the text */
            padding: 0 10px;
            color: white;
            text-decoration: none;
            font-size: 10px; /* Reduced font size */
            border-bottom: 1px solid rgba(255, 255, 255, 0.2);
            /* Prevent text from overflowing */
            white-space: nowrap; /* Keep text on one line */
            overflow: hidden; /* Hide text that doesn't fit */
            text-overflow: ellipsis; /* Add an ellipsis to truncated text */
        }

            #bottomOverlay a:hover {
                background-color: rgba(255, 255, 255, 0.2);
            }

        #bottomOverlay .reverse-btn {
            display: block;
            height: 18px;
            line-height: 18px;
            padding: 0 10px;
            color: #aaddff;
            text-decoration: none;
            font-size: 9px;
            background-color: rgba(0, 100, 200, 0.3);
            border-bottom: none;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

            #bottomOverlay .reverse-btn:hover {
                background-color: rgba(0, 100, 200, 0.6);
            }

        #bottomOverlay .zone-header {
            display: block;
            height: 24px;
            line-height: 24px;
            padding: 0 10px;
            color: #ffcc00;
            font-size: 10px;
            font-weight: bold;
            border-bottom: 1px solid rgba(255, 204, 0, 0.4);
            margin-top: 4px;
        }

        #bottomOverlay::-webkit-scrollbar {
            width: 5px; /* Optional: Customize scrollbar width */
        }

        #bottomOverlay::-webkit-scrollbar-thumb {
            background-color: rgba(255, 255, 255, 0.3); /* Optional: Customize scrollbar thumb */
            border-radius: 3px;
        }

</style>

<Watch />

<div id="bottomOverlay">
    @foreach (var (zone, routes) in RouteGroups)
    {
        <div class="zone-header">@zone</div>
        @foreach (var route in routes)
        {
            @if (route.ReverseHref.Length > 0)
            {
                <a class="reverse-btn" onclick="f(this.href); return false;" href="@route.ReverseHref">↩ reverse</a>
            }
            <a onclick="f(this.href); return false;" href="@route.Href">@route.Name</a>
        }
    }
</div>

<script>
    function f(url) {
      var iframe = document.createElement("iframe");
      iframe.style.display = "none"; // Hide the iframe
      iframe.src = url;
      document.body.appendChild(iframe); // Add it to the page
    }
</script>

