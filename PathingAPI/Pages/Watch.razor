            await jsRuntime.InvokeVoidAsync("log", token, message);
            //await hubContext.Clients.All.SendAsync("log", message, token);
        }
        catch (Exception) when (token.IsCancellationRequested) { }
        catch (JSDisconnectedException) { }
    }

